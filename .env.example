# ─────────────────────────────────────────
# .env.example  —  copy to .env.local
# Never commit .env.local to git
# ─────────────────────────────────────────

# ── Contact form (pick one) ───────────────
# Option A: Formspree  →  https://formspree.io
NEXT_PUBLIC_FORMSPREE_ID=your_form_id

# Option B: Resend     →  https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=hello@yourname.dev

# ── Analytics (optional) ─────────────────
# Vercel Analytics is enabled via vercel.json — no key needed
# For Plausible or Fathom, add your domain key here:
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourname.dev

# ── Site metadata ────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourname.dev
